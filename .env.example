# ============================================================
# Dreame Membership — Environment Variables (template)
# Copy to .env.local and fill in real values. NEVER commit .env.local.
# ============================================================

# ── Supabase ────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # SECRET — server only

# ── BigQuery ────────────────────────────────────────────────
# Dataset: `Membership` (tables: order_items, orders) — partitioned by order_date
# Project ที่ใช้จริง: elated-channel-468406-t4 (region US)
BQ_PROJECT_ID=elated-channel-468406-t4
BQ_DATASET=Membership
# Either point to a key file...
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# ...or paste raw JSON / base64 in BQ_CREDENTIALS_JSON (preferred on Vercel/Render)
# BQ_CREDENTIALS_JSON=

# ── Google Cloud Storage (optional, currently unused) ───────
GCS_PROJECT_ID=your-gcp-project-id
GCS_BUCKET_NAME=dreame-membership-files

# ── Cron ────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
CRON_SECRET=

# ── App URLs ────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=https://your-deployment.example.com

# ── SMS — ThaiBulkSMS (phone OTP signup) ────────────────────
# Generate API key/secret ที่ ThaiBulkSMS dashboard
THAIBULKSMS_API_KEY=
THAIBULKSMS_API_SECRET=
# Sender Name ที่ลงทะเบียนกับ ThaiBulkSMS (สูงสุด 11 ตัวอักษร ภาษาอังกฤษ)
# ก่อนอนุมัติให้ใช้ค่า default ที่ ThaiBulkSMS ให้มาก่อน
THAIBULKSMS_SENDER=Dreame
# "standard" (0.15฿) หรือ "corporate" (0.20฿ + OTP-ready + custom sender name)
THAIBULKSMS_FORCE=standard
# Secret ที่แชร์ระหว่าง Supabase Auth กับ Edge Function send-sms-hook
# สร้างด้วย: openssl rand -base64 32
SMS_HOOK_SECRET=

# ── Email — Resend ──────────────────────────────────────────
# Transactional email (signup verification, password reset) goes through
# Resend, not Supabase's default mailer. Sender domain MUST be verified
# at https://resend.com/domains for emails to actually deliver to inbox.
RESEND_API_KEY=re_xxx
EMAIL_FROM="Dreame <noreply@yourdomain.com>"

# ── External APIs (reserved) ────────────────────────────────
SHOPEE_PARTNER_ID=
SHOPEE_PARTNER_KEY=
LAZADA_APP_KEY=
LAZADA_APP_SECRET=

# ── Shopify Discount API (ecom-data-platform) ───────────────
# Get key at https://ecom-dashboard.fly.dev (Settings → API Keys)
SHOPIFY_DISCOUNT_API_URL=https://ecom-data-platform.onrender.com
SHOPIFY_DISCOUNT_API_KEY=
SHOPIFY_DEFAULT_SHOP_ID=dreame-thailand.myshopify.com
