# ============================================================
# Dreame Membership — Environment Variables (template)
# Copy to .env.local and fill in real values. NEVER commit .env.local.
# ============================================================

# ── Supabase ────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # SECRET — server only

# ── BigQuery ────────────────────────────────────────────────
BQ_PROJECT_ID=your-gcp-project-id
BQ_DATASET=Dashboard
# Either point to a key file...
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# ...or paste raw JSON / base64 in BQ_CREDENTIALS_JSON (preferred on Vercel/Render)
# BQ_CREDENTIALS_JSON=

# ── Google Cloud Storage (optional, currently unused) ───────
GCS_PROJECT_ID=your-gcp-project-id
GCS_BUCKET_NAME=dreame-membership-files

# ── Cron ────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
CRON_SECRET=

# ── App URLs ────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=https://your-deployment.example.com

# ── External APIs (reserved) ────────────────────────────────
SHOPEE_PARTNER_ID=
SHOPEE_PARTNER_KEY=
LAZADA_APP_KEY=
LAZADA_APP_SECRET=
